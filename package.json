{
  "name": "weniger-songs-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Songs written and song by Dr. Brad Weniger",
  "bugs": {
    "url": "https://github.com/CandeeGenerations/weniger-songs-ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:CandeeGenerations/weniger-songs-ui.git"
  },
  "license": "MIT",
  "author": "Candee Generations <admin@candeegenerations.com>",
  "scripts": {
    "build": "fnm use; REACT_APP_VERSION=$npm_package_version GENERATE_SOURCEMAP=false NODE_ENV=production craco build",
    "eject": "react-scripts eject",
    "eslint": "eslint 'src/**/*.{ts,tsx}'",
    "generate": "graphql-codegen --config codegen.yml",
    "preinstall": "npx only-allow pnpm",
    "pcheck": "npm-check -u -i 'antd' && pnpm audit",
    "prepare": "husky",
    "prettier": "prettier --cache --check --write --ignore-unknown .",
    "prettier:ci": "pnpm exec prettier --check .",
    "start": "fnm use; phase run 'REACT_APP_VERSION=$npm_package_version BROWSER=none craco start'"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "resolutions": {
    "@tootallnate/once": "^3.0.1",
    "jsonpath": "^1.3.0",
    "lodash": "^4.18.0",
    "lodash-es": "^4.18.0",
    "path-to-regexp": "^0.1.13",
    "postcss": "^8.4.31",
    "qs": "^6.14.2",
    "serialize-javascript": "^7.0.5",
    "svgo": "^2.8.1",
    "underscore": "^1.13.8",
    "webpack-dev-server": "^5.2.1"
  },
  "dependencies": {
    "@ant-design/icons": "6.2.2",
    "@apollo/client": "^4.1.9",
    "@craco/craco": "^7.1.0",
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "antd": "^5.29.3",
    "copy-text-to-clipboard": "^3.2.2",
    "craco-webpack-resolve": "^1.2.1",
    "dayjs": "^1.11.20",
    "graphql": "^16.13.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "react-scripts": "^5.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/introspection": "^5.0.1",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@graphql-codegen/typescript-react-apollo": "^4.4.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "react-app-alias": "^2.2.2",
    "sort-package-json": "^3.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "proxy": "http://localhost:5502"
}
